# =============================================================================
# Docker Ignore - Exclude from build context
# =============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.rog313/
.venv/
venv/
ENV/
env/
*.egg-info/
.eggs/
dist/
build/

# IDE/Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Git
.git/
.gitignore
.gitattributes

# Testing
tests/
pytest_cache/
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Documentation
*.md
!README.md
DOCS/

# Streamlit (explicitly excluded)
Streamlit/

# Generated reports and results (mount as volumes instead)
REPORT/
results/

# Environment files (pass via env vars or secrets)
.env
.env.*
*.env

# Logs
logs/
*.log

# Temporary files
*.tmp
*.temp
tmp*/

# OS files
.DS_Store
Thumbs.db
